{
   "version": "0.2.0",
   "configurations": [
      {
         "name": "Python: Flask Server",
         "type": "debugpy",
         "request": "launch",
         "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
         "module": "flask",
         "cwd": "${workspaceFolder}",
         "env": {
            "FLASK_APP": "backend/app.py",
            "FLASK_DEBUG": "1"
         },
         "args": [
            "run",
            "--no-reload"
         ],
         "jinja": false,
         "console": "internalConsole",
         "justMyCode": true
      },
      {
         "name": "Web: Vite React Client",
         "type": "chrome",
         "request": "launch",
         "url": "http://localhost:5173",
         "webRoot": "${workspaceFolder}/frontend",
         "sourceMaps": true
      }
   ],
   "compounds": [
      {
         "name": "Flask + Vite React",
         "configurations": [
            "Python: Flask Server",
            "Web: Vite React Client"
         ]
      }
   ]
}